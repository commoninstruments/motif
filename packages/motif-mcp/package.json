{
  "name": "@howells/motif-mcp",
  "version": "0.2.1",
  "description": "MCP server for Motif AI image generation and fal.ai utility tools.",
  "license": "MIT",
  "author": "Daniel Howells",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/howells/motif.git",
    "directory": "packages/motif-mcp"
  },
  "bin": {
    "motif-mcp": "./bin/motif-mcp"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node22",
    "dev": "tsx src/index.ts",
    "lint": "howells-check .",
    "lint:fix": "howells-fix .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@howells/motif-sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@howells/lint": "^1.1.0",
    "@howells/typescript-config": "^0.1.6",
    "@types/node": "^26.1.1",
    "tsup": "^8.0.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}

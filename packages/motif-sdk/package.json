{
  "name": "@howells/motif-sdk",
  "version": "0.12.0",
  "description": "Public Node SDK for Motif fal.ai generation, editing, utility tools, and model metadata.",
  "keywords": [
    "fal",
    "fal.ai",
    "image-generation",
    "motif",
    "sdk",
    "segmentation",
    "video-generation"
  ],
  "license": "MIT",
  "author": "Daniel Howells",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/howells/motif.git",
    "directory": "packages/motif-sdk"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./image": {
      "types": "./dist/image.d.ts",
      "import": "./dist/image.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsup",
    "dev": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsup --watch",
    "lint": "howells-check .",
    "lint:fix": "howells-fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@ai-sdk/fal": "^3.0.8",
    "@ai-sdk/google": "^4.0.12",
    "@ai-sdk/openai": "^4.0.11",
    "@ai-sdk/replicate": "^3.0.8",
    "@howells/envy": "^0.3.7",
    "ai": "^7.0.22",
    "neverthrow": "^8.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@howells/lint": "^1.1.0",
    "@howells/typescript-config": "^0.1.6",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}

{
  "name": "@howells/motif-cli",
  "version": "1.5.1",
  "description": "Agent-first fal.ai image generation CLI with structured output, dry runs, history, series, and terminal studio mode.",
  "keywords": [
    "agent-first",
    "ai",
    "cli",
    "fal",
    "fal.ai",
    "image-generation",
    "structured-output"
  ],
  "homepage": "https://github.com/howells/motif",
  "bugs": {
    "url": "https://github.com/howells/motif/issues"
  },
  "license": "MIT",
  "author": "Daniel Howells",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/howells/motif.git",
    "directory": "apps/cli"
  },
  "bin": {
    "motif": "./bin/motif"
  },
  "files": [
    "bin",
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --target node22",
    "lint": "howells-check .",
    "lint:fix": "howells-fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@howells/motif-sdk": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^15.0.0",
    "ink": "^7.1.0",
    "ink-text-input": "^6.0.0",
    "ora": "^9.4.1",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@howells/lint": "^1.1.0",
    "@howells/typescript-config": "^0.1.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "react-devtools-core": "^7.0.1",
    "tsup": "^8.0.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
